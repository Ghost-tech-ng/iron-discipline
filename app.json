{
  "expo": {
    "name": "Iron Discipline",
    "slug": "iron-discipline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ghosttech.irondiscipline",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.ghosttech.irondiscipline",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f5f5f5"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Iron Discipline needs access to save your progress photos."
        }
      ],
      "expo-sqlite"
    ],
    "scheme": "irondiscipline",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71c1e45f-2270-4c95-80bd-c43af6d83a5d"
      }
    },
    "owner": "osemwegieeghosa",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/71c1e45f-2270-4c95-80bd-c43af6d83a5d"
    }
  }
}
